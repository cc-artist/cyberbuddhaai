{
  "version": 2,
  "framework": "nextjs",
  "headers": [
    {
      "source": "/temple-images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Content-Type",
          "value": "image/*"
        }
      ]
    }
  ],
  "trailingSlash": false,
  "outputDirectory": ".next"
}